{
  "name": "botc_webapp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "add-revision": "node scripts/add-character-revision.mjs",
    "dev": "vite",
    "build": "node scripts/validate-revisions.mjs && tsc -b && vite build",
    "build:native": "node scripts/validate-revisions.mjs && tsc -b && vite build --mode native",
    "cap:sync": "npm run build:native && npx cap sync",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@capacitor/core": "^8.3.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "jsdom": "^29.0.2",
    "puppeteer": "^24.40.0",
    "typescript": "^5.8.2",
    "vite": "^6.3.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5"
  }
}
